AIRTABLE_TOKEN=pat_your_new_airtable_token
AIRTABLE_BASE_ID=app_your_airtable_base_id
AIRTABLE_REGISTER_TABLE_ID=tbl_register_table_id
# Backward-compatible legacy names. Used only when AIRTABLE_REGISTER_TABLE_ID is not set.
AIRTABLE_REGISTER_TABLE_NAME=tbl_register_table_id_or_Register
AIRTABLE_TABLE_NAME=tbl_register_table_id_or_Register
AIRTABLE_CERTIFICATES_TABLE_ID=tbl_certificates_table_id
AIRTABLE_CERTIFICATES_TABLE_NAME=Certificates

RESEND_API_KEY=re_your_resend_api_key
FROM_EMAIL=N/NPC <noreply@yourdomain.com>

VERIFY_SECRET=change_this_to_a_long_random_secret
PUBLIC_SITE_URL=https://your-vercel-project.vercel.app

# Optional. Use your official site domain after deployment.
ALLOWED_ORIGIN=https://your-vercel-project.vercel.app

# Certificate verification admin.
CERT_ADMIN_TOKEN=change_this_to_a_private_admin_token
